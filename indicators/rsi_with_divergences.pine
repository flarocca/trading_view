//@version=6
indicator("RSI with Divergences", shorttitle="RSI+Div", precision=2, max_bars_back=500)

// ============================================================
// Inputs: RSI
// ============================================================
rsiLen = input.int(14,   "RSI Length", minval=1, group="RSI")
rsiSrc = input.source(close, "Source",           group="RSI")

maType = input.string("SMA", "MA Type",
                      options=["SMA", "EMA", "WMA", "RMA"],
                      group="RSI MA", display=display.none)
maLen  = input.int(14, "MA Length", minval=1, group="RSI MA")

// ============================================================
// Inputs: Divergence detection
// ============================================================
pivotLeft      = input.int(5,  "Pivot Left Bars",              minval=1, group="Divergence", display=display.none)
pivotRight     = input.int(5,  "Pivot Right Bars",             minval=1, group="Divergence", display=display.none)
tentativeRight = input.int(1,  "Tentative Pivot Right Bars",   minval=1, group="Divergence")
rangeMin       = input.int(5,  "Min Bars Between Pairs",       minval=1, group="Divergence", display=display.none)
rangeMax       = input.int(60, "Max Bars Between Pairs",       minval=5, group="Divergence", display=display.none)
matchTolerance = input.int(10, "Price/RSI Pivot Match Tolerance (bars)",
                                                                minval=0, group="Divergence")

showRegBull = input.bool(true, "Regular Bullish (price LL / RSI HL)", group="Divergence Types")
showRegBear = input.bool(true, "Regular Bearish (price HH / RSI LH)", group="Divergence Types")
showHidBull = input.bool(true, "Hidden Bullish  (price HL / RSI LL)", group="Divergence Types")
showHidBear = input.bool(true, "Hidden Bearish  (price LH / RSI HH)", group="Divergence Types")

// ============================================================
// Inputs: Divergence quality filter
// Controls the minimum magnitude between A and B pivots.
// ============================================================
minPriceAtrMult = input.float(0.0, "Min Price Move (× ATR)", minval=0.0, step=0.1, group="Divergence Quality")
minRsiPoints    = input.float(0.0, "Min RSI Move (points)",  minval=0.0, step=0.5, group="Divergence Quality")
atrLen          = input.int(14, "ATR Length",                minval=1,  group="Divergence Quality")

// ============================================================
// Inputs: Path integrity
// An interior peak/trough between A and B only invalidates the
// divergence if it exceeds the reference pivot by more than the
// path threshold. Small overshoots are treated as noise.
// ============================================================
pathPriceAtrMult = input.float(0.3, "Path Invalidation — Price Excess (× ATR)", minval=0.0, step=0.1, group="Path Integrity")
pathRsiPoints    = input.float(3.0, "Path Invalidation — RSI Excess (points)",  minval=0.0, step=0.5, group="Path Integrity")

// ============================================================
// Inputs: Debug
// ============================================================
showPivots = input.bool(false, "Show All Pivots (debug)", group="Debug")

// ============================================================
// RSI + RSI-based MA
// ============================================================
rsi = ta.rsi(rsiSrc, rsiLen)

rsiMA = switch maType
    "SMA" => ta.sma(rsi, maLen)
    "EMA" => ta.ema(rsi, maLen)
    "WMA" => ta.wma(rsi, maLen)
    "RMA" => ta.rma(rsi, maLen)

plot(rsi,   "RSI",          color=color.new(#7E57C2, 0))
plot(rsiMA, "RSI-based MA", color=color.new(#FFB300, 0))

upperBand = hline(70, "Upper Band",  color=color.new(#787B86, 40), linestyle=hline.style_dashed)
midLine   = hline(50, "Middle Band", color=color.new(#787B86, 60), linestyle=hline.style_dotted)
lowerBand = hline(30, "Lower Band",  color=color.new(#787B86, 40), linestyle=hline.style_dashed)
fill(upperBand, lowerBand, color=color.new(#7E57C2, 92), title="RSI Background")

atrVal = ta.atr(atrLen)

// ============================================================
// CONFIRMED pivot detection
// ============================================================
phPriceRaw = ta.pivothigh(high, pivotLeft, pivotRight)
plPriceRaw = ta.pivotlow(low,   pivotLeft, pivotRight)
phRsiRaw   = ta.pivothigh(rsi,  pivotLeft, pivotRight)
plRsiRaw   = ta.pivotlow(rsi,   pivotLeft, pivotRight)

newPricePHBar = not na(phPriceRaw) ? bar_index - pivotRight : na
newPricePHVal = not na(phPriceRaw) ? high[pivotRight]       : na
newPricePLBar = not na(plPriceRaw) ? bar_index - pivotRight : na
newPricePLVal = not na(plPriceRaw) ? low[pivotRight]        : na
newRsiPHBar   = not na(phRsiRaw)   ? bar_index - pivotRight : na
newRsiPHVal   = not na(phRsiRaw)   ? rsi[pivotRight]        : na
newRsiPLBar   = not na(plRsiRaw)   ? bar_index - pivotRight : na
newRsiPLVal   = not na(plRsiRaw)   ? rsi[pivotRight]        : na

// ============================================================
// TENTATIVE pivot detection
// ============================================================
tPhPriceRaw = ta.pivothigh(high, pivotLeft, tentativeRight)
tPlPriceRaw = ta.pivotlow(low,   pivotLeft, tentativeRight)
tPhRsiRaw   = ta.pivothigh(rsi,  pivotLeft, tentativeRight)
tPlRsiRaw   = ta.pivotlow(rsi,   pivotLeft, tentativeRight)

tNewPricePHBar = not na(tPhPriceRaw) ? bar_index - tentativeRight : na
tNewPricePHVal = not na(tPhPriceRaw) ? high[tentativeRight]       : na
tNewPricePLBar = not na(tPlPriceRaw) ? bar_index - tentativeRight : na
tNewPricePLVal = not na(tPlPriceRaw) ? low[tentativeRight]        : na
tNewRsiPHBar   = not na(tPhRsiRaw)   ? bar_index - tentativeRight : na
tNewRsiPHVal   = not na(tPhRsiRaw)   ? rsi[tentativeRight]        : na
tNewRsiPLBar   = not na(tPlRsiRaw)   ? bar_index - tentativeRight : na
tNewRsiPLVal   = not na(tPlRsiRaw)   ? rsi[tentativeRight]        : na

// ============================================================
// Debug plotshapes
// ============================================================
plotshape(showPivots and not na(newPricePHBar) ? rsi[pivotRight] : na, "Price PH (debug)",
          style=shape.xcross, location=location.absolute,
          color=color.new(color.red,   0), size=size.tiny, offset=-pivotRight)
plotshape(showPivots and not na(newPricePLBar) ? rsi[pivotRight] : na, "Price PL (debug)",
          style=shape.xcross, location=location.absolute,
          color=color.new(color.green, 0), size=size.tiny, offset=-pivotRight)
plotshape(showPivots and not na(newRsiPHBar)   ? rsi[pivotRight] : na, "RSI PH (debug)",
          style=shape.circle, location=location.absolute,
          color=color.new(color.red,   0), size=size.tiny, offset=-pivotRight)
plotshape(showPivots and not na(newRsiPLBar)   ? rsi[pivotRight] : na, "RSI PL (debug)",
          style=shape.circle, location=location.absolute,
          color=color.new(color.green, 0), size=size.tiny, offset=-pivotRight)

plotshape(showPivots and not na(tNewPricePHBar) ? rsi[tentativeRight] : na, "Tent Price PH (debug)",
          style=shape.triangledown, location=location.absolute,
          color=color.new(color.red,   0), size=size.tiny, offset=-tentativeRight)
plotshape(showPivots and not na(tNewPricePLBar) ? rsi[tentativeRight] : na, "Tent Price PL (debug)",
          style=shape.triangleup,   location=location.absolute,
          color=color.new(color.green, 0), size=size.tiny, offset=-tentativeRight)
plotshape(showPivots and not na(tNewRsiPHBar)   ? rsi[tentativeRight] : na, "Tent RSI PH (debug)",
          style=shape.diamond, location=location.absolute,
          color=color.new(color.red,   0), size=size.tiny, offset=-tentativeRight)
plotshape(showPivots and not na(tNewRsiPLBar)   ? rsi[tentativeRight] : na, "Tent RSI PL (debug)",
          style=shape.diamond, location=location.absolute,
          color=color.new(color.green, 0), size=size.tiny, offset=-tentativeRight)

// ============================================================
// STATE: Confirmed waiting slots
// ============================================================
var int   waitPricePHBar = na
var float waitPricePHVal = na
var int   waitRsiPHBar   = na
var float waitRsiPHVal   = na

var int   waitPricePLBar = na
var float waitPricePLVal = na
var int   waitRsiPLBar   = na
var float waitRsiPLVal   = na

// STATE: Last two confirmed pairs
var int   currPHPriceBar = na
var float currPHPriceVal = na
var int   currPHRsiBar   = na
var float currPHRsiVal   = na
var int   prevPHPriceBar = na
var float prevPHPriceVal = na
var int   prevPHRsiBar   = na
var float prevPHRsiVal   = na

var int   currPLPriceBar = na
var float currPLPriceVal = na
var int   currPLRsiBar   = na
var float currPLRsiVal   = na
var int   prevPLPriceBar = na
var float prevPLPriceVal = na
var int   prevPLRsiBar   = na
var float prevPLRsiVal   = na

// STATE: Tentative waiting slots
var int   tWaitPricePHBar = na
var float tWaitPricePHVal = na
var int   tWaitRsiPHBar   = na
var float tWaitRsiPHVal   = na

var int   tWaitPricePLBar = na
var float tWaitPricePLVal = na
var int   tWaitRsiPLBar   = na
var float tWaitRsiPLVal   = na

// STATE: Active tentative line references
var line tPHLineRsi   = na
var line tPHLinePrice = na
var line tPLLineRsi   = na
var line tPLLinePrice = na

// Divergence flags (reset each bar)
regBull  = false
regBear  = false
hidBull  = false
hidBear  = false
tRegBull = false
tRegBear = false
tHidBull = false
tHidBear = false

// ============================================================
// CONFIRMED HIGHS
// ============================================================
pairedH   = false
pairedHPB = 0
pairedHPV = 0.0
pairedHRB = 0
pairedHRV = 0.0

if not na(newPricePHBar) and not na(newRsiPHBar)
    pairedH := true
    pairedHPB := newPricePHBar
    pairedHPV := newPricePHVal
    pairedHRB := newRsiPHBar
    pairedHRV := newRsiPHVal

if not pairedH and not na(newPricePHBar) and not na(waitRsiPHBar) and math.abs(newPricePHBar - waitRsiPHBar) <= matchTolerance
    pairedH := true
    pairedHPB := newPricePHBar
    pairedHPV := newPricePHVal
    pairedHRB := waitRsiPHBar
    pairedHRV := waitRsiPHVal

if not pairedH and not na(newRsiPHBar) and not na(waitPricePHBar) and math.abs(newRsiPHBar - waitPricePHBar) <= matchTolerance
    pairedH := true
    pairedHPB := waitPricePHBar
    pairedHPV := waitPricePHVal
    pairedHRB := newRsiPHBar
    pairedHRV := newRsiPHVal

if pairedH
    if not na(tPHLineRsi)
        line.delete(tPHLineRsi)
        tPHLineRsi := na
    if not na(tPHLinePrice)
        line.delete(tPHLinePrice)
        tPHLinePrice := na
    tWaitPricePHBar := na
    tWaitPricePHVal := na
    tWaitRsiPHBar   := na
    tWaitRsiPHVal   := na
    prevPHPriceBar := currPHPriceBar
    prevPHPriceVal := currPHPriceVal
    prevPHRsiBar   := currPHRsiBar
    prevPHRsiVal   := currPHRsiVal
    currPHPriceBar := pairedHPB
    currPHPriceVal := pairedHPV
    currPHRsiBar   := pairedHRB
    currPHRsiVal   := pairedHRV
    waitPricePHBar := na
    waitPricePHVal := na
    waitRsiPHBar   := na
    waitRsiPHVal   := na
    if not na(prevPHPriceVal)
        gapH = currPHPriceBar - prevPHPriceBar
        if gapH >= rangeMin and gapH <= rangeMax
            priceDeltaH = math.abs(currPHPriceVal - prevPHPriceVal)
            rsiDeltaH   = math.abs(currPHRsiVal   - prevPHRsiVal)
            qualityOkH  = priceDeltaH >= atrVal * minPriceAtrMult and rsiDeltaH >= minRsiPoints
            // Path integrity: static loop with break for correct buffer allocation
            float priceMaxInterior = na
            float rsiMaxInterior   = na
            if currPHPriceBar - prevPHPriceBar > 1
                for i = 1 to 500
                    int checkBar = prevPHPriceBar + i
                    if checkBar >= currPHPriceBar
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float pv = high[offset]
                        if na(priceMaxInterior) or pv > priceMaxInterior
                            priceMaxInterior := pv
            if currPHRsiBar - prevPHRsiBar > 1
                for i = 1 to 500
                    int checkBar = prevPHRsiBar + i
                    if checkBar >= currPHRsiBar
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float rv = rsi[offset]
                        if na(rsiMaxInterior) or rv > rsiMaxInterior
                            rsiMaxInterior := rv
            priceExcess = atrVal * pathPriceAtrMult
            // Regular bearish: reference HH = currPH price, reference LH = prevPH rsi
            if currPHPriceVal > prevPHPriceVal and currPHRsiVal < prevPHRsiVal and qualityOkH
                pathOkRegBearH = (na(priceMaxInterior) or priceMaxInterior <= currPHPriceVal + priceExcess) and (na(rsiMaxInterior) or rsiMaxInterior <= prevPHRsiVal + pathRsiPoints)
                if pathOkRegBearH
                    regBear := true
                    if showRegBear
                        line.new(prevPHRsiBar, prevPHRsiVal, currPHRsiBar, currPHRsiVal,
                                 color=color.red, width=2)
                        line.new(prevPHPriceBar, prevPHPriceVal, currPHPriceBar, currPHPriceVal,
                                 color=color.red, width=2, force_overlay=true)
            // Hidden bearish: reference LH = currPH price, reference HH = currPH rsi
            if currPHPriceVal < prevPHPriceVal and currPHRsiVal > prevPHRsiVal and qualityOkH
                pathOkHidBearH = (na(priceMaxInterior) or priceMaxInterior <= prevPHPriceVal + priceExcess) and (na(rsiMaxInterior) or rsiMaxInterior <= currPHRsiVal + pathRsiPoints)
                if pathOkHidBearH
                    hidBear := true
                    if showHidBear
                        line.new(prevPHRsiBar, prevPHRsiVal, currPHRsiBar, currPHRsiVal,
                                 color=color.orange, width=2)
                        line.new(prevPHPriceBar, prevPHPriceVal, currPHPriceBar, currPHPriceVal,
                                 color=color.orange, width=2, force_overlay=true)
else
    if not na(newPricePHBar)
        waitPricePHBar := newPricePHBar
        waitPricePHVal := newPricePHVal
    if not na(newRsiPHBar)
        waitRsiPHBar := newRsiPHBar
        waitRsiPHVal := newRsiPHVal

// ============================================================
// CONFIRMED LOWS
// ============================================================
pairedL   = false
pairedLPB = 0
pairedLPV = 0.0
pairedLRB = 0
pairedLRV = 0.0

if not na(newPricePLBar) and not na(newRsiPLBar)
    pairedL := true
    pairedLPB := newPricePLBar
    pairedLPV := newPricePLVal
    pairedLRB := newRsiPLBar
    pairedLRV := newRsiPLVal

if not pairedL and not na(newPricePLBar) and not na(waitRsiPLBar) and math.abs(newPricePLBar - waitRsiPLBar) <= matchTolerance
    pairedL := true
    pairedLPB := newPricePLBar
    pairedLPV := newPricePLVal
    pairedLRB := waitRsiPLBar
    pairedLRV := waitRsiPLVal

if not pairedL and not na(newRsiPLBar) and not na(waitPricePLBar) and math.abs(newRsiPLBar - waitPricePLBar) <= matchTolerance
    pairedL := true
    pairedLPB := waitPricePLBar
    pairedLPV := waitPricePLVal
    pairedLRB := newRsiPLBar
    pairedLRV := newRsiPLVal

if pairedL
    if not na(tPLLineRsi)
        line.delete(tPLLineRsi)
        tPLLineRsi := na
    if not na(tPLLinePrice)
        line.delete(tPLLinePrice)
        tPLLinePrice := na
    tWaitPricePLBar := na
    tWaitPricePLVal := na
    tWaitRsiPLBar   := na
    tWaitRsiPLVal   := na
    prevPLPriceBar := currPLPriceBar
    prevPLPriceVal := currPLPriceVal
    prevPLRsiBar   := currPLRsiBar
    prevPLRsiVal   := currPLRsiVal
    currPLPriceBar := pairedLPB
    currPLPriceVal := pairedLPV
    currPLRsiBar   := pairedLRB
    currPLRsiVal   := pairedLRV
    waitPricePLBar := na
    waitPricePLVal := na
    waitRsiPLBar   := na
    waitRsiPLVal   := na
    if not na(prevPLPriceVal)
        gapL = currPLPriceBar - prevPLPriceBar
        if gapL >= rangeMin and gapL <= rangeMax
            priceDeltaL = math.abs(currPLPriceVal - prevPLPriceVal)
            rsiDeltaL   = math.abs(currPLRsiVal   - prevPLRsiVal)
            qualityOkL  = priceDeltaL >= atrVal * minPriceAtrMult and rsiDeltaL >= minRsiPoints
            float priceMinInterior = na
            float rsiMinInterior   = na
            if currPLPriceBar - prevPLPriceBar > 1
                for i = 1 to 500
                    int checkBar = prevPLPriceBar + i
                    if checkBar >= currPLPriceBar
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float pv = low[offset]
                        if na(priceMinInterior) or pv < priceMinInterior
                            priceMinInterior := pv
            if currPLRsiBar - prevPLRsiBar > 1
                for i = 1 to 500
                    int checkBar = prevPLRsiBar + i
                    if checkBar >= currPLRsiBar
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float rv = rsi[offset]
                        if na(rsiMinInterior) or rv < rsiMinInterior
                            rsiMinInterior := rv
            priceExcessL = atrVal * pathPriceAtrMult
            // Regular bullish: reference LL = currPL price, reference HL = prevPL rsi
            if currPLPriceVal < prevPLPriceVal and currPLRsiVal > prevPLRsiVal and qualityOkL
                pathOkRegBullL = (na(priceMinInterior) or priceMinInterior >= currPLPriceVal - priceExcessL) and (na(rsiMinInterior) or rsiMinInterior >= prevPLRsiVal - pathRsiPoints)
                if pathOkRegBullL
                    regBull := true
                    if showRegBull
                        line.new(prevPLRsiBar, prevPLRsiVal, currPLRsiBar, currPLRsiVal,
                                 color=color.green, width=2)
                        line.new(prevPLPriceBar, prevPLPriceVal, currPLPriceBar, currPLPriceVal,
                                 color=color.green, width=2, force_overlay=true)
            // Hidden bullish: reference HL = currPL price, reference LL = currPL rsi
            if currPLPriceVal > prevPLPriceVal and currPLRsiVal < prevPLRsiVal and qualityOkL
                pathOkHidBullL = (na(priceMinInterior) or priceMinInterior >= prevPLPriceVal - priceExcessL) and (na(rsiMinInterior) or rsiMinInterior >= currPLRsiVal - pathRsiPoints)
                if pathOkHidBullL
                    hidBull := true
                    if showHidBull
                        line.new(prevPLRsiBar, prevPLRsiVal, currPLRsiBar, currPLRsiVal,
                                 color=color.aqua, width=2)
                        line.new(prevPLPriceBar, prevPLPriceVal, currPLPriceBar, currPLPriceVal,
                                 color=color.aqua, width=2, force_overlay=true)
else
    if not na(newPricePLBar)
        waitPricePLBar := newPricePLBar
        waitPricePLVal := newPricePLVal
    if not na(newRsiPLBar)
        waitRsiPLBar := newRsiPLBar
        waitRsiPLVal := newRsiPLVal

// ============================================================
// TENTATIVE HIGHS
// ============================================================
tPairedH   = false
tPairedHPB = 0
tPairedHPV = 0.0
tPairedHRB = 0
tPairedHRV = 0.0

if not na(tNewPricePHBar) and not na(tNewRsiPHBar)
    tPairedH := true
    tPairedHPB := tNewPricePHBar
    tPairedHPV := tNewPricePHVal
    tPairedHRB := tNewRsiPHBar
    tPairedHRV := tNewRsiPHVal

if not tPairedH and not na(tNewPricePHBar) and not na(tWaitRsiPHBar) and math.abs(tNewPricePHBar - tWaitRsiPHBar) <= matchTolerance
    tPairedH := true
    tPairedHPB := tNewPricePHBar
    tPairedHPV := tNewPricePHVal
    tPairedHRB := tWaitRsiPHBar
    tPairedHRV := tWaitRsiPHVal

if not tPairedH and not na(tNewRsiPHBar) and not na(tWaitPricePHBar) and math.abs(tNewRsiPHBar - tWaitPricePHBar) <= matchTolerance
    tPairedH := true
    tPairedHPB := tWaitPricePHBar
    tPairedHPV := tWaitPricePHVal
    tPairedHRB := tNewRsiPHBar
    tPairedHRV := tNewRsiPHVal

if (not na(tNewPricePHBar) or not na(tNewRsiPHBar))
    if not na(tPHLineRsi)
        line.delete(tPHLineRsi)
        tPHLineRsi := na
    if not na(tPHLinePrice)
        line.delete(tPHLinePrice)
        tPHLinePrice := na

if tPairedH
    tWaitPricePHBar := na
    tWaitPricePHVal := na
    tWaitRsiPHBar   := na
    tWaitRsiPHVal   := na
    if not na(currPHPriceVal)
        tGapH = tPairedHPB - currPHPriceBar
        if tGapH >= rangeMin and tGapH <= rangeMax
            tPriceDeltaH = math.abs(tPairedHPV - currPHPriceVal)
            tRsiDeltaH   = math.abs(tPairedHRV - currPHRsiVal)
            tQualityOkH  = tPriceDeltaH >= atrVal * minPriceAtrMult and tRsiDeltaH >= minRsiPoints
            float tPriceMaxInterior = na
            float tRsiMaxInterior   = na
            if tPairedHPB - currPHPriceBar > 1
                for i = 1 to 500
                    int checkBar = currPHPriceBar + i
                    if checkBar >= tPairedHPB
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float pv = high[offset]
                        if na(tPriceMaxInterior) or pv > tPriceMaxInterior
                            tPriceMaxInterior := pv
            if tPairedHRB - currPHRsiBar > 1
                for i = 1 to 500
                    int checkBar = currPHRsiBar + i
                    if checkBar >= tPairedHRB
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float rv = rsi[offset]
                        if na(tRsiMaxInterior) or rv > tRsiMaxInterior
                            tRsiMaxInterior := rv
            tPriceExcess = atrVal * pathPriceAtrMult
            // Tentative regular bearish: reference HH = tentative price, reference LH = currPH rsi
            if tPairedHPV > currPHPriceVal and tPairedHRV < currPHRsiVal and tQualityOkH
                tPathOkRegBearH = (na(tPriceMaxInterior) or tPriceMaxInterior <= tPairedHPV + tPriceExcess) and (na(tRsiMaxInterior) or tRsiMaxInterior <= currPHRsiVal + pathRsiPoints)
                if tPathOkRegBearH
                    tRegBear := true
                    if showRegBear
                        tPHLineRsi := line.new(currPHRsiBar, currPHRsiVal, tPairedHRB, tPairedHRV,
                                               color=color.red, width=2, style=line.style_dashed)
                        tPHLinePrice := line.new(currPHPriceBar, currPHPriceVal, tPairedHPB, tPairedHPV,
                                                 color=color.red, width=2, style=line.style_dashed, force_overlay=true)
            // Tentative hidden bearish: reference LH = currPH price, reference HH = tentative rsi
            if tPairedHPV < currPHPriceVal and tPairedHRV > currPHRsiVal and tQualityOkH
                tPathOkHidBearH = (na(tPriceMaxInterior) or tPriceMaxInterior <= currPHPriceVal + tPriceExcess) and (na(tRsiMaxInterior) or tRsiMaxInterior <= tPairedHRV + pathRsiPoints)
                if tPathOkHidBearH
                    tHidBear := true
                    if showHidBear
                        tPHLineRsi := line.new(currPHRsiBar, currPHRsiVal, tPairedHRB, tPairedHRV,
                                               color=color.orange, width=2, style=line.style_dashed)
                        tPHLinePrice := line.new(currPHPriceBar, currPHPriceVal, tPairedHPB, tPairedHPV,
                                                 color=color.orange, width=2, style=line.style_dashed, force_overlay=true)
else
    if not na(tNewPricePHBar)
        tWaitPricePHBar := tNewPricePHBar
        tWaitPricePHVal := tNewPricePHVal
    if not na(tNewRsiPHBar)
        tWaitRsiPHBar := tNewRsiPHBar
        tWaitRsiPHVal := tNewRsiPHVal

// ============================================================
// TENTATIVE LOWS
// ============================================================
tPairedL   = false
tPairedLPB = 0
tPairedLPV = 0.0
tPairedLRB = 0
tPairedLRV = 0.0

if not na(tNewPricePLBar) and not na(tNewRsiPLBar)
    tPairedL := true
    tPairedLPB := tNewPricePLBar
    tPairedLPV := tNewPricePLVal
    tPairedLRB := tNewRsiPLBar
    tPairedLRV := tNewRsiPLVal

if not tPairedL and not na(tNewPricePLBar) and not na(tWaitRsiPLBar) and math.abs(tNewPricePLBar - tWaitRsiPLBar) <= matchTolerance
    tPairedL := true
    tPairedLPB := tNewPricePLBar
    tPairedLPV := tNewPricePLVal
    tPairedLRB := tWaitRsiPLBar
    tPairedLRV := tWaitRsiPLVal

if not tPairedL and not na(tNewRsiPLBar) and not na(tWaitPricePLBar) and math.abs(tNewRsiPLBar - tWaitPricePLBar) <= matchTolerance
    tPairedL := true
    tPairedLPB := tWaitPricePLBar
    tPairedLPV := tWaitPricePLVal
    tPairedLRB := tNewRsiPLBar
    tPairedLRV := tNewRsiPLVal

if (not na(tNewPricePLBar) or not na(tNewRsiPLBar))
    if not na(tPLLineRsi)
        line.delete(tPLLineRsi)
        tPLLineRsi := na
    if not na(tPLLinePrice)
        line.delete(tPLLinePrice)
        tPLLinePrice := na

if tPairedL
    tWaitPricePLBar := na
    tWaitPricePLVal := na
    tWaitRsiPLBar   := na
    tWaitRsiPLVal   := na
    if not na(currPLPriceVal)
        tGapL = tPairedLPB - currPLPriceBar
        if tGapL >= rangeMin and tGapL <= rangeMax
            tPriceDeltaL = math.abs(tPairedLPV - currPLPriceVal)
            tRsiDeltaL   = math.abs(tPairedLRV - currPLRsiVal)
            tQualityOkL  = tPriceDeltaL >= atrVal * minPriceAtrMult and tRsiDeltaL >= minRsiPoints
            float tPriceMinInterior = na
            float tRsiMinInterior   = na
            if tPairedLPB - currPLPriceBar > 1
                for i = 1 to 500
                    int checkBar = currPLPriceBar + i
                    if checkBar >= tPairedLPB
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float pv = low[offset]
                        if na(tPriceMinInterior) or pv < tPriceMinInterior
                            tPriceMinInterior := pv
            if tPairedLRB - currPLRsiBar > 1
                for i = 1 to 500
                    int checkBar = currPLRsiBar + i
                    if checkBar >= tPairedLRB
                        break
                    int offset = bar_index - checkBar
                    if offset >= 0
                        float rv = rsi[offset]
                        if na(tRsiMinInterior) or rv < tRsiMinInterior
                            tRsiMinInterior := rv
            tPriceExcessL = atrVal * pathPriceAtrMult
            // Tentative regular bullish: reference LL = tentative price, reference HL = currPL rsi
            if tPairedLPV < currPLPriceVal and tPairedLRV > currPLRsiVal and tQualityOkL
                tPathOkRegBullL = (na(tPriceMinInterior) or tPriceMinInterior >= tPairedLPV - tPriceExcessL) and (na(tRsiMinInterior) or tRsiMinInterior >= currPLRsiVal - pathRsiPoints)
                if tPathOkRegBullL
                    tRegBull := true
                    if showRegBull
                        tPLLineRsi := line.new(currPLRsiBar, currPLRsiVal, tPairedLRB, tPairedLRV,
                                               color=color.green, width=2, style=line.style_dashed)
                        tPLLinePrice := line.new(currPLPriceBar, currPLPriceVal, tPairedLPB, tPairedLPV,
                                                 color=color.green, width=2, style=line.style_dashed, force_overlay=true)
            // Tentative hidden bullish: reference HL = currPL price, reference LL = tentative rsi
            if tPairedLPV > currPLPriceVal and tPairedLRV < currPLRsiVal and tQualityOkL
                tPathOkHidBullL = (na(tPriceMinInterior) or tPriceMinInterior >= currPLPriceVal - tPriceExcessL) and (na(tRsiMinInterior) or tRsiMinInterior >= tPairedLRV - pathRsiPoints)
                if tPathOkHidBullL
                    tHidBull := true
                    if showHidBull
                        tPLLineRsi := line.new(currPLRsiBar, currPLRsiVal, tPairedLRB, tPairedLRV,
                                               color=color.aqua, width=2, style=line.style_dashed)
                        tPLLinePrice := line.new(currPLPriceBar, currPLPriceVal, tPairedLPB, tPairedLPV,
                                                 color=color.aqua, width=2, style=line.style_dashed, force_overlay=true)
else
    if not na(tNewPricePLBar)
        tWaitPricePLBar := tNewPricePLBar
        tWaitPricePLVal := tNewPricePLVal
    if not na(tNewRsiPLBar)
        tWaitRsiPLBar := tNewRsiPLBar
        tWaitRsiPLVal := tNewRsiPLVal

// ============================================================
// Alerts
// ============================================================
alertcondition(regBull  and showRegBull, "RSI Regular Bullish Divergence",
               "RSI Regular Bullish Divergence on {{ticker}} {{interval}}")
alertcondition(regBear  and showRegBear, "RSI Regular Bearish Divergence",
               "RSI Regular Bearish Divergence on {{ticker}} {{interval}}")
alertcondition(hidBull  and showHidBull, "RSI Hidden Bullish Divergence",
               "RSI Hidden Bullish Divergence on {{ticker}} {{interval}}")
alertcondition(hidBear  and showHidBear, "RSI Hidden Bearish Divergence",
               "RSI Hidden Bearish Divergence on {{ticker}} {{interval}}")
alertcondition(tRegBull and showRegBull, "RSI Tentative Regular Bullish Divergence",
               "Tentative RSI Regular Bullish Divergence on {{ticker}} {{interval}}")
alertcondition(tRegBear and showRegBear, "RSI Tentative Regular Bearish Divergence",
               "Tentative RSI Regular Bearish Divergence on {{ticker}} {{interval}}")
alertcondition(tHidBull and showHidBull, "RSI Tentative Hidden Bullish Divergence",
               "Tentative RSI Hidden Bullish Divergence on {{ticker}} {{interval}}")
alertcondition(tHidBear and showHidBear, "RSI Tentative Hidden Bearish Divergence",
               "Tentative RSI Hidden Bearish Divergence on {{ticker}} {{interval}}")
